{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@crm/shared": ["../../packages/shared/src"],
      "@crm/shared/*": ["../../packages/shared/src/*"],
      "@crm/i18n": ["../../packages/i18n/src"],
      "@crm/i18n/*": ["../../packages/i18n/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
