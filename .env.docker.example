# Plantilla para Docker. Copiar a `.env` (raíz) y completar con claves reales.
# El archivo `.env` está en .gitignore — NUNCA se commitea.
#
#   cp .env.docker.example .env

# ── Supabase (públicas: se hornean en build) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Dominio / locale ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_DOMAIN=turisteacrm.com
NEXT_PUBLIC_ROOT_URL=https://turisteacrm.com
NEXT_PUBLIC_DEFAULT_LOCALE=es
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Secretos de servidor (runtime, NO se hornean) ────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=postgresql://...
TOKEN_ENCRYPTION_KEY=

# ── Integraciones opcionales ─────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
CUPOS_SUPABASE_URL=
CUPOS_SUPABASE_KEY=
